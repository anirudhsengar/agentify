{
  "name": "agentify",
  "version": "0.1.0",
  "description": "One terminal command for the full life of an agentic codebase: audit existing code, start greenfield projects, and export harness-native agent surfaces.",
  "type": "module",
  "keywords": [
    "agentic-engineering",
    "agents",
    "codebase-audit",
    "agentic-development"
  ],
  "license": "MIT",
  "author": "Anirudh Sengar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anirudhsengar/agentify.git"
  },
  "bugs": {
    "url": "https://github.com/anirudhsengar/agentify/issues"
  },
  "homepage": "https://github.com/anirudhsengar/agentify#readme",
  "bin": {
    "agentify": "./bin/agentify.js"
  },
  "files": [
    "bin",
    "dist",
    "scaffold",
    "docs",
    "packaged",
    "skills-lock.json",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "overrides": {
    "@smithy/util-buffer-from": "4.4.7"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "test:unit": "node tests/scripts/run-test-files.mjs --exclude tests/generation-pipeline.test.ts",
    "test:all": "npm run test:generation-pipeline && npm run test:unit && bash tests/run.sh",
    "test": "npm run typecheck && npm run test:all",
    "test:generation-pipeline": "tsx tests/generation-pipeline.test.ts",
    "test:package": "node tests/package/installed-cli-smoke.mjs",
    "test:fixtures": "npm run test:unit",
    "test:generated-output": "tsx tests/artifacts-renderers.test.ts && tsx tests/generated-output-quality.test.ts && tsx tests/core/expert-outcome.test.ts && tsx tests/core/smoke-evidence.test.ts && tsx tests/core/release-qualification.test.ts",
    "test:scaffold-e2e": "bash scaffold/tests/run.sh",
    "test:security-redteam": "tsx tests/audit/defense-hardening.test.ts && bash scaffold/tests/test-workflow-simulation.sh",
    "score:expert-outcomes": "tsx src/core/scripts/score-expert-outcomes.ts",
    "verify:smoke-evidence": "tsx src/core/scripts/verify-smoke-evidence.ts",
    "qualify:release-evidence": "tsx src/core/scripts/qualify-release-evidence.ts",
    "release:check": "npm run typecheck && npm run test:all && npm run test:package",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run release:check",
    "inspect-log": "node dist/core/audit/scripts/inspect-log.mjs",
    "build": "node scripts/build.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    "./package.json": "./package.json"
  }
}
